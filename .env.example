# Gold Prices API
METALS_API_KEY=your_metals_api_key_here
METALS_API_URL=https://api.metals.live/v1/spot/gold

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_ADMIN_SDK=your_admin_sdk_json

# AI/Translation APIs (Optional)
OPENAI_API_KEY=your_openai_key_for_article_generation

# Environment
NODE_ENV=production
SITE_URL=https://your-domain.com

# Update Frequency (in minutes)
UPDATE_INTERVAL=30

# Supported Languages (comma separated)
SUPPORTED_LANGUAGES=en,ar,es,fr,de,it,pt,ru,ja,zh,ko,hi,tr,pl,nl
